<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="4.0" client="site" method="upgrade">
    <name>mod_news</name>
    <author>Assistant</author>
    <version>1.0.0</version>
    <description>Module to display Joomla articles with search, category filtering and pagination.</description>
    <files>
        <filename module="mod_news">mod_news.php</filename>
        <filename>helper.php</filename>
        <folder>tmpl</folder>
        <folder>language</folder>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/en-GB.mod_news.ini</language>
    </languages>
</extension>
